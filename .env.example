# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Supabase Postgres) ────────────────────────────
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_5_CLASSES=price_...
STRIPE_PRICE_10_CLASSES=price_...
STRIPE_PRICE_20_CLASSES=price_...
STRIPE_PRICE_MONTHLY=price_...

# ─── Resend (Email) ─────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@zenstudio.com

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@zenstudio.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@zenstudio.com

# ─── Cron ────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret
